// AutoMarket AI - Prisma Schema
// Personal 1-man marketing automation hub
//
// Supports BOTH:
//   - PostgreSQL (Supabase) for production — set DATABASE_URL to postgresql://...
//   - SQLite for local dev — set DATABASE_URL to file:./dev.db
//
// Provider is auto-detected from DATABASE_URL.
// To switch providers, change DATABASE_URL in .env and run `bun run db:push`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Production: PostgreSQL on Supabase
  // Use pooler URL for both DATABASE_URL and DIRECT_URL (direct host may be blocked)
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model BrandProfile {
  id              String   @id @default(cuid())
  name            String
  tagline         String?
  industry        String?
  targetAudience  String?
  brandVoice      String?
  toneKeywords    String?
  primaryColor    String?
  logoUrl         String?
  hashtagSets     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  posts           ContentPost[]
  assets          Asset[]

  @@map("brand_profiles")
}

model ContentPost {
  id           String   @id @default(cuid())
  title        String
  body         String
  platform     String   // instagram, facebook, linkedin, twitter, tiktok
  status       String   @default("draft") // draft, scheduled, published, failed
  hashtags     String?
  scheduledAt  DateTime?
  publishedAt  DateTime?
  brandId      String?
  assetUrls    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brand        BrandProfile? @relation(fields: [brandId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([platform])
  @@index([scheduledAt])
  @@map("content_posts")
}

model Asset {
  id        String   @id @default(cuid())
  name      String
  type      String   // image, video, audio, document
  url       String
  tags      String?
  brandId   String?
  createdAt DateTime @default(now())

  brand     BrandProfile? @relation(fields: [brandId], references: [id], onDelete: SetNull)

  @@index([type])
  @@map("assets")
}

model AutomationRule {
  id           String   @id @default(cuid())
  name         String
  description  String?
  trigger      String   // daily, weekly, on_event, content_added
  action       String   // generate_post, repurpose, schedule
  config       String   // JSON string with rule config
  active       Boolean  @default(true)
  lastRunAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("automation_rules")
}

model AnalyticsSnapshot {
  id           String   @id @default(cuid())
  platform     String
  metric       String   // reach, engagement, followers, clicks
  value        Float
  recordedAt   DateTime @default(now())

  @@index([platform, metric])
  @@map("analytics_snapshots")
}
