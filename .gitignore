# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit secrets
.env
.env.local
.env.production
.env.*.local
# Allow the example template to be committed
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local config & private files
local-*
.claude
.z-ai-config
skills/

# Logs
*.log
dev.log
dev.out.log
server.log

# Database (SQLite local dev — Supabase PostgreSQL is used in production)
db/
*.db
*.db-journal

# Generated Prisma client (auto-generated on install)
# (Prisma puts client in node_modules, so nothing to ignore here)

# Internal scripts (sandbox-related)
.zscripts/

# Downloaded files (user-generated screenshots, exports)
download/

# Examples folder (not needed in production)
examples/

# Mini-services (not used in this app)
mini-services/

# Caddy config (sandbox-only reverse proxy)
Caddyfile

# IDE
.vscode/
.idea/
*.swp
*.swo
