# ============================================
# AutoMarket AI — Environment Variables
# ============================================
# Copy this file to .env (local) or set these in Vercel Project Settings → Environment Variables
# See README.md for full setup instructions.

# --- Database (Supabase PostgreSQL) ---
# Get these from: Supabase Dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL: Use the "Connection pooling" URL (port 6543, with ?pgbouncer=true)
#   Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# DIRECT_URL: Use the "Direct connection" URL (port 5432, no pgbouncer)
#   Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# --- Google Gemini AI (for content generation) ---
# FREE: 1,500 requests/day, 1M tokens/min
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"
# Optional: override model (default: gemini-2.0-flash)
# GEMINI_MODEL="gemini-2.0-flash"

# --- Next.js ---
# Automatically set by Vercel. For local dev:
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Optional: NextAuth (for future multi-user support) ---
# NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
# NEXTAUTH_URL="http://localhost:3000"
