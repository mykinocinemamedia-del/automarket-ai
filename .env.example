# ============================================
# AutoMarket AI — Environment Variables
# ============================================
# Copy this file to .env (local) or set these in Vercel Project Settings → Environment Variables

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# --- Supabase Client SDK (REST API access) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-anon-or-service-key"

# --- AI Provider: Groq (RECOMMENDED — fast & free) ---
# Free tier: 14,400 requests/day, 30 RPM
# Get key: https://console.groq.com/keys
GROQ_API_KEY="gsk_your_groq_api_key_here"
GROQ_MODEL="llama-3.3-70b-versatile"

# --- AI Provider: Google Gemini (FALLBACK) ---
# Free tier: 1,500 requests/day (may have quota issues for new keys)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL="gemini-2.0-flash"

# --- Next.js ---
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
